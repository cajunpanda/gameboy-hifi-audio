# PlatformIO build artifacts
firmware/.pio/
firmware/.pioenvs/
firmware/.piolibdeps/
firmware/.vscode/

# ESP-IDF / PlatformIO generated files (regenerated each build)
firmware/build/
# NOTE: firmware/CMakeLists.txt is intentionally TRACKED (not ignored). PlatformIO
# only generates it when absent and respects a present one; it sets the IDF
# project name, which is embedded in the app descriptor and used as the OTA
# identity gate (ble_config.c). A regenerated project(firmware) would fail that
# gate, so the customized project(gameboy-hifi-audio) must be committed.
firmware/sdkconfig
firmware/sdkconfig.old
firmware/sdkconfig.prod
firmware/managed_components/
firmware/dependencies.lock

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Development history, bring-up notes, and war stories (not part of the public repo)
history/

# Third-party reference material (e.g. the GBA mainboard schematic)
hardware/agb/references/

# KiCad generated / per-user / IDE noise
hardware/**/*-backups/
hardware/**/.history/
hardware/**/*-erc.rpt
hardware/**/*-drc.rpt
hardware/**/*.kicad_prl
hardware/**/_autosave-*.kicad_sch
hardware/**/_autosave-*.kicad_pcb
hardware/**/fp-info-cache
hardware/**/~*.lck
hardware/**/*.3mf
hardware/**/*.kicad_pcb.zip
hardware/**/gerbers/
hardware/**/pcbway-gerbers/
hardware/**/jlcpcb/
hardware/**/analysis/
hardware/**/datasheets/

# Python
tools/__pycache__/
tools/.venv/

# Claude Code local state
.claude/

# Scratch media and browser-automation artifacts
scratch-media/
.playwright-cli/
